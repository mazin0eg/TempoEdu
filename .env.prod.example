# Copy this file to .env.prod before running production compose

# REQUIRED: Use a long random secret
JWT_SECRET=replace-with-a-very-long-random-secret

# Your public domain or IP used by browser clients
# Example: https://tempoedu.example.com
CORS_ORIGIN=http://your-server-ip-or-domain

# Optional WebRTC ICE settings (recommended in production)
# Comma-separated URLs
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
# Set true to force TURN relay for strict NAT/corporate networks
VITE_FORCE_TURN_RELAY=false

# Optional backup settings
BACKUP_RETENTION_DAYS=7
TZ=UTC
